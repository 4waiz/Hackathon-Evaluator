# Database - PostgreSQL (use Neon, Vercel Postgres, or local PostgreSQL)
# For Neon: postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
# For local: postgresql://postgres:postgres@localhost:5432/hackeval
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hackeval"

# OpenAI API Key - required for AI-powered evaluation
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# OpenAI Model - defaults to gpt-4o
OPENAI_MODEL="gpt-4o"

# App secret for session signing
APP_SECRET="change-this-to-a-random-secret-in-production"

# Mock mode - set to "true" to use mock AI responses (no API key needed)
MOCK_AI="false"

# Max upload size in MB
MAX_UPLOAD_SIZE_MB="50"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"
